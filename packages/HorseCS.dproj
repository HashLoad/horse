<?xml version="1.0" encoding="utf-8"?>
<!--
  HorseCS.dproj  —  Delphi project file for the HorseCS runtime package
  ========================================================================
  Targets:
    Win32 / Win64 / Linux64

  To build from the command line:
    msbuild HorseCS.dproj /t:Build /p:Config=Release;Platform=Win64

  To build all platforms:
    msbuild HorseCS.dproj /t:Build /p:Config=Release;Platform=Win32
    msbuild HorseCS.dproj /t:Build /p:Config=Release;Platform=Win64
    msbuild HorseCS.dproj /t:Build /p:Config=Release;Platform=Linux64
-->
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <ProjectGuid>{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}</ProjectGuid>
    <ProjectVersion>19.4</ProjectVersion>
    <FrameworkType>None</FrameworkType>
    <MainSource>HorseCS.dpk</MainSource>
    <Base>True</Base>
    <Config Condition="'$(Config)'==''">Release</Config>
    <Platform Condition="'$(Platform)'==''">Win64</Platform>
    <TargetedPlatforms>3</TargetedPlatforms>
    <!-- 3 = Win32 + Win64.  Add Linux64 = 7 when cross-compiler is available -->
    <AppType>Package</AppType>
  </PropertyGroup>

  <!-- ── Release configuration ──────────────────────────────────────────── -->
  <PropertyGroup Condition="'$(Config)'=='Release'">
    <CfgParent>Base</CfgParent>
    <Defines>RELEASE</Defines>
    <DCC_Optimize>true</DCC_Optimize>
    <DCC_DebugInformation>0</DCC_DebugInformation>
    <DCC_LocalSymbols>false</DCC_LocalSymbols>
    <DCC_UnitAliases>WinTypes=Windows;WinProcs=Windows;DbiTypes=BDE;DbiProcs=BDE;DbiErrs=BDE</DCC_UnitAliases>
  </PropertyGroup>

  <!-- ── Debug configuration ────────────────────────────────────────────── -->
  <PropertyGroup Condition="'$(Config)'=='Debug'">
    <CfgParent>Base</CfgParent>
    <Defines>DEBUG</Defines>
    <DCC_Optimize>false</DCC_Optimize>
    <DCC_DebugInformation>2</DCC_DebugInformation>
    <DCC_LocalSymbols>true</DCC_LocalSymbols>
    <DCC_Assertions>true</DCC_Assertions>
  </PropertyGroup>

  <!-- ── Win32 platform ─────────────────────────────────────────────────── -->
  <PropertyGroup Condition="'$(Platform)'=='Win32'">
    <DCC_ExeOutput>.\bin\Win32\$(Config)</DCC_ExeOutput>
    <DCC_DcuOutput>.\dcu\Win32\$(Config)</DCC_DcuOutput>
    <DCC_BplOutput>.\bpl\Win32\$(Config)</DCC_BplOutput>
    <DCC_DcpOutput>.\dcp\Win32\$(Config)</DCC_DcpOutput>
    <Manifest_File>None</Manifest_File>
  </PropertyGroup>

  <!-- ── Win64 platform ─────────────────────────────────────────────────── -->
  <PropertyGroup Condition="'$(Platform)'=='Win64'">
    <DCC_ExeOutput>.\bin\Win64\$(Config)</DCC_ExeOutput>
    <DCC_DcuOutput>.\dcu\Win64\$(Config)</DCC_DcuOutput>
    <DCC_BplOutput>.\bpl\Win64\$(Config)</DCC_BplOutput>
    <DCC_DcpOutput>.\dcp\Win64\$(Config)</DCC_DcpOutput>
    <Manifest_File>None</Manifest_File>
  </PropertyGroup>

  <!-- ── Linux64 platform ───────────────────────────────────────────────── -->
  <PropertyGroup Condition="'$(Platform)'=='Linux64'">
    <DCC_ExeOutput>.\bin\Linux64\$(Config)</DCC_ExeOutput>
    <DCC_DcuOutput>.\dcu\Linux64\$(Config)</DCC_DcuOutput>
    <DCC_BplOutput>.\bpl\Linux64\$(Config)</DCC_BplOutput>
    <DCC_DcpOutput>.\dcp\Linux64\$(Config)</DCC_DcpOutput>
  </PropertyGroup>

  <!-- ── Search paths (shared across all platforms) ─────────────────────── -->
  <PropertyGroup>
    <DCC_UnitSearchPath>
      ..\..\horse-fork\src;
      $(DCC_UnitSearchPath)
    </DCC_UnitSearchPath>
    <DCC_Namespace>System;Xml;Data;Datasnap;Web;Soap;$(DCC_Namespace)</DCC_Namespace>
  </PropertyGroup>

  <!-- ── Build targets ──────────────────────────────────────────────────── -->
  <ItemGroup>
    <DelphiCompile Include="$(MainSource)">
      <MainSource>MainSource</MainSource>
    </DelphiCompile>
  </ItemGroup>

  <Import Project="$(BDS)\bin\CodeGear.Delphi.Targets"
          Condition="Exists('$(BDS)\bin\CodeGear.Delphi.Targets')" />
  <Import Project="$(APPDATA)\Embarcadero\$(BDSAPPDATABASEDIR)\$(PRODUCTVERSION)\UserTools.proj"
          Condition="Exists('$(APPDATA)\Embarcadero\$(BDSAPPDATABASEDIR)\$(PRODUCTVERSION)\UserTools.proj')" />
</Project>
